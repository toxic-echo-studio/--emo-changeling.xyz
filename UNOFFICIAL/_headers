# Glo# Globalne zasady bezpieczeństwa i blokada modyfikacji kodu przez Cloudflare
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.emo-changeling.xyz https://toxic-echo.studio; connect-src 'self' https://*.emo-changeling.xyz;

# Grafika i assety wizualne - agresywny cache, ale z absolutnym zakazem korporacyjnej kompresji (no-transform)
/img/*
  Cache-Control: public, max-age=31536000, immutable, no-transform

/css/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=604800, no-transform

# Dynamiczne pliki tekstowe i sitemapy - całkowity zakaz cache'owania, boty zawsze mają ssać świeży stan
/sitemap.xml
  Cache-Control: no-cache, no-store, must-revalidate
/humans.txt
  Cache-Control: no-cache, no-store, must-revalidate

# Cały kram AI SEO - twarde no-cache, żeby guardraile aktualizowały się natychmiast po deployu
/llms.txt
  Cache-Control: no-cache, no-store, must-revalidate
/ai.json
  Cache-Control: no-cache, no-store, must-revalidate
/llms.toml
  Cache-Control: no-cache, no-store, must-revalidate