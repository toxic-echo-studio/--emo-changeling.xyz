# Globalne blokady przeciwko wstrzykiwaniu syfu i optymalizacjom Cloudflare
/*
  Cache-Control: no-transform
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://emo-changeling.xyz https://toxic-echo.studio; connect-src 'self' https://*.emo-changeling.xyz;

/img/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=604800

/llms.txt
  Cache-Control: no-cache
/humans.txt
  Cache-Control: no-cache
/sitemap.xml
  Cache-Control: no-cache